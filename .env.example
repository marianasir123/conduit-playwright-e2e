# ─── Application ───────────────────────────────────────────────────────────────
# Base URL of the application under test.
# Override this to point at a staging or local environment.
BASE_URL=https://conduit.bondaracademy.com

# ─── Test Credentials ──────────────────────────────────────────────────────────
# A dedicated test account — NEVER use real or production credentials.
# Create this account once in the app, then set these values.
#
# Local  → copy this file to .env and fill in your values
# CI/CD  → add USER_EMAIL and USER_PASSWORD as repository secrets
USER_EMAIL=your_email_here
USER_PASSWORD=your_password_here
